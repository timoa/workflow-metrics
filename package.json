{
	"name": "workflow-metrics",
	"private": true,
	"version": "0.1.18",
	"type": "module",
	"description": "Open-source dashboard for GitHub Actions metrics with AI-powered optimization",
	"keywords": [
		"github-actions",
		"metrics",
		"dashboard",
		"svelte",
		"analytics"
	],
	"license": "MIT",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "pnpm run build && pnpm exec wrangler pages deploy .svelte-kit/cloudflare --project-name=workflow-metrics",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@ai-sdk/mistral": "3.0.21",
		"@fortawesome/fontawesome-free": "7.2.0",
		"@octokit/rest": "22.0.1",
		"@supabase/ssr": "0.8.0",
		"@supabase/supabase-js": "2.98.0",
		"@xyflow/svelte": "1.5.1",
		"ai": "6.0.105",
		"dompurify": "3.3.2",
		"highlight.js": "11.11.1",
		"layerchart": "1.0.13",
		"marked": "17.0.3",
		"yaml": "2.8.2",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "9.39.3",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/kit": "2.53.4",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tailwindcss/vite": "4.2.1",
		"@vitest/coverage-v8": "3.2.4",
		"bits-ui": "2.16.2",
		"clsx": "2.1.1",
		"eslint": "9.39.3",
		"eslint-plugin-svelte": "3.15.0",
		"globals": "17.3.0",
		"lucide-svelte": "0.575.0",
		"mode-watcher": "1.1.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.0",
		"prettier-plugin-tailwindcss": "0.7.2",
		"sharp": "0.34.5",
		"svelte": "5.53.6",
		"svelte-check": "4.4.4",
		"tailwind-merge": "3.5.0",
		"tailwindcss": "4.2.1",
		"tailwindcss-animate": "1.0.7",
		"tw-animate-css": "1.4.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.56.1",
		"vite": "6.4.1",
		"vitest": "3.2.4",
		"wrangler": "4.69.0"
	},
	"pnpm": {
		"auditConfig": {
			"ignoreGhsas": [
				"GHSA-3ppc-4f35-3m26"
			]
		},
		"overrides": {
			"cookie": "1.1.1",
			"devalue": "5.6.4",
			"flatted": "3.4.0",
			"undici": "7.24.0",
			"zod": "4.3.6"
		}
	}
}
